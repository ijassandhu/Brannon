    <record model="ir.ui.view" id="view_inventory_import_wizard_form">
      <field name="name">inventory.import.wizard.form</field>
      <field name="model">inventory.import.wizard</field>
      <field name="arch" type="xml">
        <form string="Import Inventory">
          <group>
            <field name="file_name"/>
            <field name="file_data" filename="file_name"/>
            <field name="delimiter"/>
            <field name="has_header"/>
            <field name="batch_size"/>
          </group>
          <group string="Header Mapping">
            <field name="line_ids" nolabel="1">
              <tree editable="bottom" create="false" delete="false">
                <field name="source_header" readonly="1"/>
                <field name="target_key"/>
              </tree>
            </field>
          </group>
          <footer>
            <button string="Import" type="object" name="action_import" class="btn-primary"/>
            <button string="Cancel" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

