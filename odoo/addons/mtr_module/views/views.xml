      <field name="name">mtr.pdf.upload.wizard.form</field>
      <field name="model">mtr.pdf.upload.wizard</field>
      <field name="arch" type="xml">
        <form string="Upload MTR Certificate">
          <sheet>
            <group>
              <field name="file_name"/>
