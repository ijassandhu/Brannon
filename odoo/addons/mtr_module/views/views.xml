<odoo>
  <data>
    <record model="ir.ui.view" id="view_mtr_data_form">
      <field name="name">mtr.data.form</field>
      <field name="model">mtr.data</field>
      <field name="arch" type="xml">
        <form string="MTR Data">
          <header>
            <button name="action_resend_to_n8n" type="object" string="Resend to n8n"
                    class="btn-secondary"
                    attrs="{'invisible': [('n8n_status', '=', 'processed')]}"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="batch_number"/>
                <field name="heat_number"/>
                <field name="piece_no"/>
                <field name="grade"/>
                <field name="manufacturer"/>
                <field name="certificate_number"/>
                <field name="certificate_date"/>
              </group>
              <group>
                <field name="country_of_melt"/>
                <field name="country_of_manufacture"/>
                <field name="uploaded_at"/>
                <field name="n8n_status" invisible="1"/>
              </group>
            </group>
            <notebook>
              <page string="Chemistry">
                <group>
                  <field name="c_element"/>
                  <field name="mn_element"/>
                  <field name="si_element"/>
                  <field name="p_element"/>
                  <field name="s_element"/>
                  <field name="b_element"/>
                  <field name="v_element"/>
                  <field name="nb_element"/>
                  <field name="ti_element"/>
                  <field name="al_element"/>
                  <field name="cu_element"/>
                  <field name="ni_element"/>
                  <field name="cr_element"/>
                  <field name="mo_element"/>
                  <field name="ce" readonly="1"/>
                </group>
              </page>
              <page string="Mechanical">
                <group>
                  <field name="yield_strength"/>
                  <field name="tensile_strength"/>
                  <field name="elongation"/>
                  <field name="reduction_area"/>
                  <field name="hardness"/>
                  <field name="thickness"/>
                  <field name="impact_charpy"/>
                  <field name="plate_dimension"/>
                  <field name="direction"/>
                </group>
              </page>
              <page string="Impact">
                <group>
                  <field name="impact_test_temp"/>
                  <field name="impact_coupon_size"/>
                  <field name="impact_specimen_1"/>
                  <field name="impact_specimen_2"/>
                  <field name="impact_specimen_3"/>
                  <field name="impact_average"/>
                </group>
              </page>
            </notebook>
          </sheet>
          <div class="oe_chatter">
            <field name="message_follower_ids" widget="mail_followers"/>
            <field name="message_ids" widget="mail_thread"/>
          </div>
        </form>
      </field>
    </record>

